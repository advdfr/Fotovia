<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/container_parent"
    android:background="#1A1A1A">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        style="@style/ScrollStyle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/adView"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="42dp">


            <ImageView
                android:id="@+id/hamburger_ic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:padding="6dp"
                android:src="@drawable/hamburger_ic"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="MissingConstraints" />
            <ImageView
                android:id="@+id/close_ic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:visibility="invisible"
                android:padding="6dp"
                android:src="@drawable/hamburger_ic"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="MissingConstraints" />



            <androidx.cardview.widget.CardView
                android:id="@+id/linearLayout"
                android:layout_width="250dp"
                android:layout_height="170dp"
                android:layout_margin="8dp"
                android:visibility="invisible"
                android:clickable="true"
                android:elevation="6dp"
                android:focusable="true"
                android:outlineAmbientShadowColor="@color/white"
                android:outlineSpotShadowColor="@color/white"
                android:translationX="-18dp"
                app:cardBackgroundColor="#1B1E23"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:layout_constraintStart_toEndOf="@id/hamburger_ic"
                app:layout_constraintTop_toBottomOf="@id/hamburger_ic">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/rate_us_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:src="@drawable/rate_us_ic" />

                    <ImageView
                        android:id="@+id/share_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:src="@drawable/share_ic" />
                    <ImageView
                        android:id="@+id/privacy_policy_iv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:src="@drawable/privacy_ic" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <ImageView
                android:id="@+id/title_ic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/title_ic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="MissingConstraints" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_neon_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/neon_ic"
                app:layout_constraintBottom_toTopOf="@+id/lin_frame_effect"
                app:layout_constraintEnd_toStartOf="@id/guideline"
                app:layout_constraintStart_toStartOf="@id/hamburger_ic"
                app:layout_constraintTop_toBottomOf="@id/hamburger_ic"
                app:shapeAppearanceOverlay="@style/circleImageView2"
                tools:ignore="MissingConstraints" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_frame_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/frame_ic"
                app:layout_constraintEnd_toEndOf="@id/lin_neon_effect"
                app:layout_constraintStart_toStartOf="@id/lin_neon_effect"
                app:layout_constraintTop_toBottomOf="@id/lin_neon_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2"
                tools:ignore="MissingConstraints" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="240dp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_pix"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="16dp"
                android:scaleType="centerCrop"
                android:src="@drawable/pix_lab_ic"
                app:layout_constraintBottom_toTopOf="@+id/card_ai_magic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/guideline"
                app:layout_constraintTop_toTopOf="@id/lin_neon_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2"
                tools:ignore="MissingConstraints" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_ai_magic"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#8A2BE2"
                app:cardCornerRadius="16dp"
                app:layout_constraintBottom_toBottomOf="@id/lin_frame_effect"
                app:layout_constraintEnd_toEndOf="@id/lin_pix"
                app:layout_constraintStart_toStartOf="@id/lin_pix"
                app:layout_constraintTop_toBottomOf="@id/lin_pix">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="24dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_neon_effect_svg" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:text="AI Magic"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_wings_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/wings_ic"
                app:layout_constraintEnd_toStartOf="@id/lin_drip_effect"
                app:layout_constraintStart_toStartOf="@id/lin_frame_effect"
                app:layout_constraintTop_toBottomOf="@id/lin_frame_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_drip_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/drip_ic"
                app:layout_constraintEnd_toEndOf="@id/lin_pix"
                app:layout_constraintStart_toEndOf="@id/lin_wings_effect"
                app:layout_constraintTop_toTopOf="@id/lin_wings_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2"
                tools:ignore="MissingConstraints" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_motion_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/motion_ic"
                app:layout_constraintEnd_toEndOf="@id/lin_drip_effect"
                app:layout_constraintStart_toEndOf="@id/guideline_two"
                app:layout_constraintTop_toTopOf="@id/lin_blur_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2"
                tools:ignore="MissingConstraints" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_two"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="170dp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_blur_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/blur_ic"
                app:layout_constraintEnd_toStartOf="@id/guideline_two"
                app:layout_constraintStart_toStartOf="@id/lin_wings_effect"
                app:layout_constraintTop_toBottomOf="@id/lin_wings_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_b_w_effect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/b_w_ic"
                app:layout_constraintEnd_toEndOf="@id/lin_motion_effect"
                app:layout_constraintStart_toStartOf="@id/lin_motion_effect"
                app:layout_constraintTop_toBottomOf="@id/lin_motion_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lin_my_photos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/my_creations"
                app:layout_constraintEnd_toEndOf="@id/lin_b_w_effect"
                app:layout_constraintStart_toStartOf="@id/lin_blur_effect"
                app:layout_constraintTop_toBottomOf="@id/lin_blur_effect"
                app:shapeAppearanceOverlay="@style/circleImageView2" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <RelativeLayout
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/adView"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        style="@style/BannerAdsView"
        android:minHeight="@dimen/margin_55" />
</androidx.constraintlayout.widget.ConstraintLayout>
